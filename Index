const GROUND = H - 44;
const WORLD  = 1700;

let platforms=[], obstacles=[], bees=[], flowers=[], particles=[], clouds=[];
let gate={}, boy={};

function rnd(a,b){ return a+Math.random()*(b-a); }
function rndInt(a,b){ return Math.floor(rnd(a,b)); }

function buildWorld(){
  platforms=[]; obstacles=[]; bees=[]; flowers=[]; particles=[];

  // Ground
  platforms.push({x:0, y:GROUND+18, w:WORLD, h:28, t:'g'});

  // Floating platforms — random each run, clear path guaranteed
  let cx_ = 130;
  const numP = rndInt(8,12);
  for(let i=0;i<numP;i++){
    cx_ += rndInt(70,125);
    if(cx_ > WORLD-210) break;
    platforms.push({x:cx_, y:GROUND - rndInt(44,100), w:rndInt(55,85), h:12, t:'p'});
  }

  // Obstacles on ground
  const usedX = [];
  for(let i=0;i<rndInt(5,7);i++){
    let ox = rndInt(160, WORLD-240);
    let tries=0;
    while(usedX.some(u=>Math.abs(u-ox)<75) && tries<20){ ox=rndInt(160,WORLD-240); tries++; }
    usedX.push(ox);
    obstacles.push({x:ox, y:GROUND-18, w:20, h:18});
  }

  // Bees — randomized height + position, always jumpable-over
  const beeSeed = [
    {xMin:220, xMax:360},  {xMin:480, xMax:620},
    {xMin:720, xMax:860},  {xMin:1000,xMax:1150},
    {xMin:1250,xMax:1380},
  ];
  beeSeed.forEach(s=>{
    bees.push({
      x:rndInt(s.xMin,s.xMax), y:GROUND-rndInt(50,95), w:18, h:14,
      bx:0, range:rndInt(55,88), spd:rnd(.8,1.5), dir:1, fr:0, ft:0, alive:true
    });
    bees[bees.length-1].bx = bees[bees.length-1].x;
  });

  // Collectible hearts
  for(let i=0;i<rndInt(7,11);i++)
    flowers.push({x:rndInt(120,WORLD-200), y:GROUND-rndInt(18,34), got:false, bob:Math.random()*6.28});

  // Clouds
  clouds=[];
  for(let i=0;i<14;i++)
    clouds.push({x:rnd(0,WORLD), y:rnd(12,65), w:rnd(44,78), spd:rnd(.2,.45)});

  gate = {x:WORLD-138, y:GROUND-94, w:50, h:94};
  boy  = {x:WORLD-88, y:GROUND-37, w:20, h:37};
}

