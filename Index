const FB_PROJECT = "love-quest-4e428";
const FB_URL = `https://firestore.googleapis.com/v1/projects/${FB_PROJECT}/databases/(default)/documents`;

let leaderboard = [];

async function loadLeaderboard(){
  try {
    const r = await fetch(`${FB_URL}/scores?orderBy=score&pageSize=10`);
    const data = await r.json();
    if(!data.documents){ leaderboard=[]; return; }
    leaderboard = data.documents.map(d=>({
      name: d.fields.name.stringValue,
      score: parseInt(d.fields.score.integerValue),
      won: d.fields.won.booleanValue
    }));
    leaderboard.sort((a,b)=>b.score-a.score);
  } catch(e){ leaderboard=[]; }
}

async function saveScore(name, pts, won){
  try {
    await fetch(`${FB_URL}/scores`, {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        fields:{
          name:{stringValue: name},
          score:{integerValue: pts},
          won:{booleanValue: won},
          ts:{integerValue: Date.now()}
        }
      })
    });
    await loadLeaderboard();
  } catch(e){}
  // also update local copy immediately
  leaderboard.push({name, score:pts, won});
  leaderboard.sort((a,b)=>b.score-a.score);
  leaderboard = leaderboard.slice(0,10);
}

loadLeaderboard();

// scoreboard state
let sbT = 0;

function drawScoreboard(){
  sbT++;
  const bg=cx.createLinearGradient(0,0,0,H);
  bg.addColorStop(0,'#08040f'); bg.addColorStop(.5,'#180830'); bg.addColorStop(1,'#2a0a30');
  cx.fillStyle=bg; cx.fillRect(0,0,W,H);

  titleParticles.forEach(p=>{
    p.x+=p.vx; p.y+=p.vy; p.life+=.008;
    if(p.y<-4||p.life>p.maxLife){ p.y=H+4; p.x=Math.random()*W; p.life=0; }
    cx.globalAlpha=Math.sin(p.life*Math.PI)*.5;
    cx.fillStyle=p.col; cx.fillRect(Math.round(p.x),Math.round(p.y),p.size,p.size);
    cx.globalAlpha=1;
  });

  cx.strokeStyle='#c84888'; cx.lineWidth=3; cx.strokeRect(2,2,W-4,H-4);
  [[8,8],[W-10,8],[8,H-10],[W-10,H-10]].forEach(([px,py])=>{
    cx.fillStyle='#ffaad4'; cx.fillRect(px-2,py-2,4,4);
  });

  // header
  pxTextShadow('SCOREBOARD 🏆', W/2, 12, 8, '#ffaad4', '#6a0040', 2, 2);
  // global badge
  pxTextShadow('🌐 global', W/2, 26, 4, '#e870aa', '#2a0020', 1, 1);
  cx.fillStyle='#c84888';
  for(let i=20;i<W-20;i+=6) cx.fillRect(i,36,3,1);

  if(leaderboard.length === 0){
    // spinning dots loading indicator
    const dots = '.'.repeat((Math.floor(sbT/15)%4));
    pxTextShadow('loading'+dots, W/2, H/2-16, 6, '#cc88aa', '#1a0018', 1, 1);
    pxTextShadow('be the first to play! 💕', W/2, H/2+8, 5, '#e870aa', '#1a0018', 1, 1);
  } else {
    leaderboard.slice(0,10).forEach((e,i)=>{
      const a = Math.min((sbT - i*6)/14, 1);
      if(a<=0) return;
      cx.globalAlpha = a;
      const y = 44 + i*20;
      // row highlight for top 3
      if(i<3){
        cx.fillStyle=`rgba(200,72,136,${.06+i*.02})`; cx.fillRect(12,y-1,W-24,17);
      }
      // medal / rank
      const medal = ['🥇','🥈','🥉'][i]||'';
      if(medal){
        cx.save(); cx.font='10px serif'; cx.textAlign='left'; cx.textBaseline='top';
        cx.fillText(medal, 14, y+2); cx.restore();
      } else {
        pxTextShadow(`${i+1}.`, 16, y+4, 4, '#6a3858', '#1a0018', 1, 1);
      }
      // name (truncate to 8 chars)
      const nm = e.name.length>8 ? e.name.slice(0,8)+'~' : e.name;
      const nameCol = i===0?'#ffaad4':i<3?'#ff80c0':'#ffccdd';
      pxTextShadow(nm, 46, y+4, 5, nameCol, '#1a0018', 1, 1);
      // won heart
      if(e.won){
        cx.save(); cx.font='8px serif'; cx.textAlign='left'; cx.textBaseline='top';
        cx.fillText('💕', W-68, y+3); cx.restore();
      }
      // score
      const sc = e.score.toString();
      pxTextShadow(sc, W-16, y+4, 5, e.won?'#ff80c0':'#cc88aa', '#1a0018', 1, 1);
      cx.globalAlpha=1;
    });
  }

  cx.fillStyle='#c84888';
  for(let i=20;i<W-20;i+=6) cx.fillRect(i,H-26,3,1);
  if(Math.floor(sbT/30)%2===0){
    pxTextShadow('tap to go back', W/2, H-18, 5, '#ffaad4', '#3a0030', 1, 1);
  }
}


function handleScreenTap(){
  if(state==='title'){
    initAudio(); sfxClick();
    state='nameinput'; activateNameInput();
  } else if(state==='story' && cv._storyDone){
    initAudio(); sfxClick();
    startGame();
  }
}

cv.addEventListener('click', e=>{
  initAudio();
  if(state==='scoreboard'){ sfxClick(); state='title'; return; }
  if(state==='title'){
    // check scoreboard button first
    const rect=cv.getBoundingClientRect();
    const scale=W/rect.width;
    const tx=(e.clientX-rect.left)*scale;
    const ty=(e.clientY-rect.top)*scale;
    const sb=cv._sbBtn;
    if(sb && tx>=sb.x && tx<=sb.x+sb.w && ty>=sb.y && ty<=sb.y+sb.h){
      sfxClick(); sbT=0; state='scoreboard'; loadLeaderboard(); return;
    }
    sfxClick(); state='nameinput'; activateNameInput(); return;
  }
  if(state==='nameinput'){
    const rect=cv.getBoundingClientRect();
    const scale=W/rect.width;
    const tx=(e.clientX-rect.left)*scale;
    const ty=(e.clientY-rect.top)*scale;
    const btn=cv._nameBtn;
    if(btn && tx>=btn.x && tx<=btn.x+btn.w && ty>=btn.y && ty<=btn.y+btn.h){
      submitName();
    }
    return;
  }
  if(state==='story' && cv._storyDone){ sfxClick(); startGame(); return; }
  if(state==='story' && !cv._storyDone){ storyT += 40; }
});
cv.addEventListener('touchstart', e=>{
  e.preventDefault(); initAudio();
  if(state==='scoreboard'){ sfxClick(); state='title'; return; }
  if(state==='title'){
    const rect=cv.getBoundingClientRect();
    const scale=W/rect.width;
    const t=e.touches[0];
    const tx=(t.clientX-rect.left)*scale;
    const ty=(t.clientY-rect.top)*scale;
    const sb=cv._sbBtn;
    if(sb && tx>=sb.x && tx<=sb.x+sb.w && ty>=sb.y && ty<=sb.y+sb.h){
      sfxClick(); sbT=0; state='scoreboard'; loadLeaderboard(); return;
    }
    sfxClick(); state='nameinput'; activateNameInput(); return;
  }
  if(state==='nameinput'){
    const rect=cv.getBoundingClientRect();
    const scale=W/rect.width;
    const t=e.touches[0];
    const tx=(t.clientX-rect.left)*scale;
    const ty=(t.clientY-rect.top)*scale;
    const btn=cv._nameBtn;
    if(btn && tx>=btn.x && tx<=btn.x+btn.w && ty>=btn.y && ty<=btn.y+btn.h){
      submitName();
    }
    return;
  }
  if(state==='story' && cv._storyDone){ sfxClick(); startGame(); return; }
  if(state==='story'){ storyT+=40; }
},{passive:false});

