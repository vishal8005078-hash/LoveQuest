//  MAIN LOOP
// ════════════════════════════════════════
let last=0;
function loop(ts){
  const dt=Math.min((ts-last)/16,3); last=ts;
  cx.clearRect(0,0,W,H);

  if(state==='title'){
    document.getElementById('hud').classList.add('hidden');
    document.getElementById('controls').classList.add('hidden');
    drawTitleScreen();
  } else if(state==='scoreboard'){
    document.getElementById('hud').classList.add('hidden');
    document.getElementById('controls').classList.add('hidden');
    drawScoreboard();
  } else if(state==='nameinput'){
    document.getElementById('hud').classList.add('hidden');
    document.getElementById('controls').classList.add('hidden');
    drawNameScreen();
  } else if(state==='story'){
    document.getElementById('hud').classList.add('hidden');
    document.getElementById('controls').classList.add('hidden');
    drawStoryScreen();
  } else if(state==='playing'){
    drawBG();
    platforms.forEach(drawPlatform);
    obstacles.forEach(drawObstacle);
    flowers.forEach(drawFlower);
    drawGate();
    const rY=Math.sin(Date.now()*.002)*3;
    drawBoy(boy.x,boy.y,rY,true);
    drawParticles();
    bees.forEach(drawBee);
    drawGirl(P.x,P.y,P.dir,P.fr,P.inv);
    updatePhysics(); updateBees(); updateParts(); updateHUD();
  } else if(state==='win'){
    updateWin(); updateParts();
    drawWinScene();
  } else if(state==='dead'){
    drawBG();
    platforms.forEach(drawPlatform); obstacles.forEach(drawObstacle);
    flowers.forEach(drawFlower); drawGate();
    drawBoy(boy.x,boy.y,0,false); drawParticles(); bees.forEach(drawBee);
    drawGirl(P.x,P.y,P.dir,P.fr,0); updateParts();
  }

  requestAnimationFrame(loop);
}
requestAnimationFrame(loop);
