// ════════════════════════════════════════
//  WIN SEQUENCE
// ════════════════════════════════════════
let winT=0, winPhase=0;
let winGirlX=0, winGirlY=0;
let winCamCur=0, winCamTgt=0;
let winDialIdx=0, winDialT=0;
let winFinalT=0;

const DIALS=[
  {who:'v', text:'you made it...'},
  {who:'v', text:'i waited so long.'},
  {who:'g', text:'i crossed the bees for you!'},
  {who:'v', text:'will you be mine?'},
  {who:'g', text:'yes. always.'},
];

function initWin(){
  winT=0; winPhase=0;
  winGirlX=P.x; winGirlY=P.y;
  winCamCur=camX;
  winCamTgt=Math.max(0, Math.min(WORLD-W, gate.x - W*.52));
  winDialIdx=0; winDialT=0; winFinalT=0;
}

function updateWin(){
  winT++;
  // Phase 0: camera pans to gate
  if(winPhase===0){
    winCamCur += (winCamTgt - winCamCur) * .05;
    camX = winCamCur;
    if(winT > 80) winPhase=1;
  }
  // Phase 1: girl walks to boy
  if(winPhase===1){
    const tgtX = gate.x - 36;
    winGirlX += (tgtX - winGirlX) * .04;
    if(winT > 140) { winPhase=2; winDialT=0; winDialIdx=0; }
  }
  // Phase 2: dialogue — auto advance every 130 frames (~2 sec each)
  if(winPhase===2){
    winDialT++;
    if(winDialT%2===0) spawnHearts(gate.x-60+Math.random()*50, gate.y+30, 1);
    // auto advance
    if(winDialT > 130){
      winDialIdx++;
      winDialT=0;
      if(winDialIdx >= DIALS.length){ winPhase=3; winFinalT=0; }
    }
  }
  // Phase 3: final screen
  if(winPhase===3) winFinalT++;
}

function advanceDial(){
  if(winPhase<2) return;
  sfxClick();
  winDialIdx++;
  winDialT=0;
  if(winDialIdx >= DIALS.length){ winPhase=3; }
}

function drawDialBubble(text, who){
  // who: 'v'=right side, 'g'=left side
  const bW=170, bH=26;
  const bX = who==='v' ? W-bW-14 : 14;
  const bY = 30;
  // shadow
  cx.fillStyle='rgba(0,0,0,.4)'; cx.fillRect(bX+3,bY+3,bW,bH);
  // box
  cx.fillStyle='rgba(18,4,30,.95)'; cx.fillRect(bX,bY,bW,bH);
  cx.strokeStyle=who==='v'?'#c84888':'#e870aa'; cx.lineWidth=2; cx.strokeRect(bX,bY,bW,bH);
  // inner glow edge
  cx.strokeStyle=who==='v'?'#ff80c055':'#ffaad455'; cx.lineWidth=1;
  cx.strokeRect(bX+3,bY+3,bW-6,bH-6);
  // tail (pixel style)
  const tx = who==='v' ? bX+bW-20 : bX+15;
  cx.fillStyle='rgba(18,4,30,.95)';
  cx.fillRect(tx, bY+bH, 4, 5);
  cx.fillRect(tx+2, bY+bH+4, 2, 3);
  cx.strokeStyle=who==='v'?'#c84888':'#e870aa'; cx.lineWidth=1;
  cx.strokeRect(tx,bY+bH,4,5); cx.strokeRect(tx+2,bY+bH+4,2,3);
  // who label
  cx.save(); cx.font='4px "Press Start 2P"';
  cx.fillStyle=who==='v'?'#c84888':'#e870aa';
  cx.textAlign= who==='v'?'right':'left';
  cx.textBaseline='top';
  cx.fillText(who==='v'?'Vishal':pName, who==='v'?bX+bW-5:bX+5, bY+bH+10);
  cx.restore();
  // text
  const alpha=Math.min(winDialT/12,1);
  cx.globalAlpha=alpha;
  cx.save(); cx.font='6px "Press Start 2P"'; cx.fillStyle='#ffccdd';
  cx.textAlign='center'; cx.textBaseline='middle';
  cx.fillText(text, bX+bW/2, bY+bH/2);
  cx.restore();
  cx.globalAlpha=1;
}

function drawFinalScreen(){
  // fade in overlay
  const a=Math.min(winFinalT/40,.92);
  cx.fillStyle=`rgba(4,0,10,${a})`; cx.fillRect(0,0,W,H);

  if(winFinalT<20) return;

  // pixel border glow
  cx.save(); cx.shadowColor='#c84888'; cx.shadowBlur=18;
  cx.strokeStyle='#c84888'; cx.lineWidth=3; cx.strokeRect(8,8,W-16,H-16);
  cx.restore();

  // decorative top pixel dots
  cx.fillStyle='#c84888';
  for(let i=30;i<W-30;i+=8) cx.fillRect(i,22,3,3);
  for(let i=30;i<W-30;i+=8) cx.fillRect(i,H-22,3,3);

  // draw pixel boy & girl together, close
  const cx2=W/2, cy2=H/2+10;
  // girl
  drawWalkGirl(cx2-28, cy2-20, 0);
  // boy (mirrored toward her)
  cx.save(); cx.translate(cx2+6, cy2-20);
  cx.fillStyle='#2255aa'; cx.fillRect(3,18,5,12); cx.fillRect(8,18,5,12);
  cx.fillStyle='#1a1a3a'; cx.fillRect(2,30,7,3); cx.fillRect(8,30,7,3);
  cx.fillStyle='#3a7a3a'; cx.fillRect(2,8,13,12);
  cx.fillStyle='#ffd4a8'; cx.fillRect(3,-3,11,11);
  cx.fillStyle='#3a1a08'; cx.fillRect(2,-3,13,4); cx.fillRect(2,1,2,3);
  cx.fillStyle='#1a0808'; cx.fillRect(5,0,2,2); cx.fillRect(9,0,2,2);
  cx.fillStyle='#ffa0a0'; cx.fillRect(4,3,2,1); cx.fillRect(10,3,2,1);
  // rose extended toward girl
  cx.fillStyle='#cc2244'; cx.fillRect(-8,5,7,4); cx.fillRect(-10,3,3,3);
  cx.fillStyle='#2a6a2a'; cx.fillRect(-7,9,2,6);
  cx.restore();

  // pulsing hearts above
  const ht=winFinalT;
  [[cx2-10,cy2-46],[cx2,cy2-52],[cx2+10,cy2-46]].forEach(([hx,hy],i)=>{
    const s=2+Math.abs(Math.sin(ht*.08+i))*2;
    const alpha=.5+Math.abs(Math.sin(ht*.08+i))*.5;
    cx.globalAlpha=alpha;
    cx.fillStyle='#ff69b4';
    cx.fillRect(hx-s/2,hy,s/2,s/2); cx.fillRect(hx,hy,s/2,s/2);
    cx.fillRect(hx-s*.7,hy+s*.3,s*1.4,s*.5); cx.fillRect(hx-s*.4,hy+s*.8,s*.8,s*.4);
    cx.fillRect(hx-s*.2,hy+s*1.2,s*.4,s*.3);
    cx.globalAlpha=1;
  });

  // names
  if(winFinalT>25){
    const nb=Math.min((winFinalT-25)/15,1);
    cx.globalAlpha=nb;
    pxTextShadow(pName+' & Vishal', W/2, cy2+24, 8, '#ffaad4', '#6a0040', 2, 2);
    cx.globalAlpha=1;
  }

  // together forever line
  if(winFinalT>45){
    const a2=Math.min((winFinalT-45)/15,1);
    cx.globalAlpha=a2;
    pxTextShadow('together, forever', W/2, cy2+44, 5, '#cc88aa', '#3a0028', 1, 1);
    cx.globalAlpha=1;
  }

  // decorative rule
  if(winFinalT>55){
    cx.globalAlpha=Math.min((winFinalT-55)/10,1)*.6;
    cx.fillStyle='#c84888';
    for(let i=50;i<W-50;i+=6) cx.fillRect(i, cy2+58, 3, 1);
    cx.globalAlpha=1;
  }

  // dev message
  if(winFinalT>65){
    const a3=Math.min((winFinalT-65)/15,1);
    cx.globalAlpha=a3;
    pxTextShadow('from ur romantic dev', W/2, H-36, 5, '#8a3868', '#00000000', 0, 0);
    cx.globalAlpha=1;
  }

  // tap to replay
  if(winFinalT>80 && Math.floor(winFinalT/28)%2===0){
    pxTextShadow('tap to play again', W/2, H-18, 5, '#c84888', '#3a0028', 1, 1);
  }
}

function drawWinScene(){
  drawBG();
  platforms.forEach(drawPlatform);
  drawGate();
  const rY=Math.sin(winT*.05)*3;
  drawBoy(boy.x, boy.y, rY, true);
  // girl — frozen position lerped toward gate
  const gfr = winPhase>=1 ? winT : 0;
  drawGirl(winGirlX, winGirlY, 1, gfr, 0);
  drawParticles();
  if(winPhase===2){
    const d=DIALS[Math.min(winDialIdx, DIALS.length-1)];
    if(d) drawDialBubble(d.text, d.who);
  }
  if(winPhase===3) drawFinalScreen();
}

