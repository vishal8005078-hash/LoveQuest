function drawBG(){
  const g=cx.createLinearGradient(0,0,0,H);
  g.addColorStop(0,'#100618'); g.addColorStop(.4,'#281040'); g.addColorStop(.7,'#5c2854'); g.addColorStop(1,'#a05448');
  cx.fillStyle=g; cx.fillRect(0,0,W,H);

  // moon
  cx.fillStyle='#ffe8f5';
  cx.beginPath(); cx.arc(W*.76,30,18,0,Math.PI*2); cx.fill();
  cx.fillStyle='#c8a8c0';
  cx.beginPath(); cx.arc(W*.76+7,24,13,0,Math.PI*2); cx.fill();
  const mg=cx.createRadialGradient(W*.76,30,14,W*.76,30,48);
  mg.addColorStop(0,'rgba(255,200,230,.16)'); mg.addColorStop(1,'rgba(255,200,230,0)');
  cx.fillStyle=mg; cx.beginPath(); cx.arc(W*.76,30,48,0,Math.PI*2); cx.fill();

  // stars
  cx.fillStyle='#ffe8f5';
  for(let i=0;i<32;i++){
    const sx=((i*131+17)%W), sy=((i*89+11)%88);
    const ss=Math.abs(Math.sin(Date.now()/1100+i))*1.4+.4;
    cx.fillRect(sx,sy,ss,ss);
  }

  // far trees
  cx.fillStyle='#1c0828';
  for(let i=0;i<26;i++){
    const tx=((i*112-camX*.12)%(W+120)+W+120)%(W+120)-50;
    const th=36+((i*19)%26);
    cx.fillRect(tx-3,H-44-th,6,th);
    cx.fillRect(tx-12,H-44-th-22,24,26);
  }
  // mid trees
  cx.fillStyle='#2a1048';
  for(let i=0;i<18;i++){
    const tx=((i*162-camX*.30)%(W+180)+W+180)%(W+180)-70;
    const th=48+((i*23)%36);
    cx.fillRect(tx-5,GROUND-th,10,th);
    cx.fillRect(tx-17,GROUND-th-34,34,38);
    cx.fillRect(tx-11,GROUND-th-50,22,18);
    cx.fillStyle='#c06098'; cx.fillRect(tx-16,GROUND-th-36,4,4); cx.fillRect(tx+12,GROUND-th-28,4,4);
    cx.fillStyle='#2a1048';
  }
  // bushes — warm dusty purple
  for(let i=0;i<14;i++){
    const bx=((i*192-camX*.56)%(W+220)+W+220)%(W+220)-70;
    cx.fillStyle='#48285a'; cx.fillRect(bx-16,GROUND+8,32,14); cx.fillRect(bx-7,GROUND+3,14,10);
    cx.fillStyle='#5a3870'; cx.fillRect(bx-13,GROUND+10,26,8);
    cx.fillStyle='#e8a8c8'; cx.fillRect(bx-8,GROUND+5,3,3); cx.fillRect(bx+5,GROUND+7,3,3);
  }

  clouds.forEach(c=>{
    const cpx=Math.round(c.x-camX*.26);
    cx.fillStyle='rgba(255,210,232,.3)';
    cx.fillRect(cpx,c.y+6,c.w,12); cx.fillRect(cpx+7,c.y,c.w-14,12);
    c.x-=c.spd*.24; if(c.x<-90) c.x=WORLD+40;
  });
}

function drawPlatform(p){
  const px=Math.round(p.x-camX), py=Math.round(p.y);
  if(px>W+10||px+p.w<-10) return;
  if(p.t==='g'){
    cx.fillStyle='#7a9868'; cx.fillRect(px,py,p.w,6);
    cx.fillStyle='#5a7848'; cx.fillRect(px,py,p.w,2);
    cx.fillStyle='#7a5848'; cx.fillRect(px,py+6,p.w,p.h-6);
    cx.fillStyle='#6a4838';
    for(let i=0;i<p.w;i+=18) cx.fillRect(px+i+4,py+9,7,3);
  } else {
    cx.fillStyle='#8a9878'; cx.fillRect(px,py,p.w,5);
    cx.fillStyle='#6a7858'; cx.fillRect(px,py,p.w,2);
    cx.fillStyle='#8d6e63'; cx.fillRect(px,py+5,p.w,p.h-5);
    cx.fillStyle='#c4a882';
    for(let i=0;i<p.w;i+=9) cx.fillRect(px+i+2,py,3,3);
  }
}

function drawObstacle(o){
  const px=Math.round(o.x-camX), py=Math.round(o.y);
  if(px>W+10||px<-10) return;
  cx.fillStyle='#7a5548'; cx.fillRect(px,py,o.w,o.h);
  cx.fillStyle='#a18878'; cx.fillRect(px+2,py,o.w-4,3);
  cx.fillStyle='#6a4538'; cx.fillRect(px+2,py+4,o.w-4,3);
}

function drawFlower(f){
  if(f.got) return;
  f.bob+=.05;
  const px=Math.round(f.x-camX), py=Math.round(f.y+Math.sin(f.bob)*3);
  if(px<-10||px>W+10) return;
  cx.fillStyle='#ff5599';
  cx.fillRect(px,py,2,2); cx.fillRect(px+3,py,2,2);
  cx.fillRect(px-1,py+2,7,2); cx.fillRect(px,py+4,5,2);
  cx.fillRect(px+1,py+6,3,2); cx.fillRect(px+2,py+8,1,1);
}

function drawGate(){
  const gx=Math.round(gate.x-camX), gy=Math.round(gate.y);
  if(gx>W+10||gx+gate.w<-10) return;
  const gw=gate.w, gh=gate.h;
  // shadow
  cx.fillStyle='rgba(0,0,0,.22)'; cx.fillRect(gx+4,gy+4,gw,gh);
  // posts
  cx.fillStyle='#6d4c41'; cx.fillRect(gx,gy+10,10,gh-10);
  cx.fillStyle='#8d6e63'; cx.fillRect(gx+1,gy+12,5,gh-16);
  cx.fillStyle='#5d3f30'; cx.fillRect(gx,gy+10,10,3);
  cx.fillStyle='#6d4c41'; cx.fillRect(gx+gw-10,gy+10,10,gh-10);
  cx.fillStyle='#8d6e63'; cx.fillRect(gx+gw-6,gy+12,5,gh-16);
  cx.fillStyle='#5d3f30'; cx.fillRect(gx+gw-10,gy+10,10,3);
  // cross beams
  cx.fillStyle='#8d6e63'; cx.fillRect(gx,gy+28,gw,8); cx.fillStyle='#a1887f'; cx.fillRect(gx+1,gy+29,gw-2,4);
  cx.fillStyle='#8d6e63'; cx.fillRect(gx,gy+52,gw,7); cx.fillStyle='#a1887f'; cx.fillRect(gx+1,gy+53,gw-2,3);
  // arch top
  cx.fillStyle='#6d4c41'; cx.fillRect(gx,gy+6,gw,10);
  cx.fillStyle='#8d6e63'; cx.fillRect(gx+1,gy+7,gw-2,6);
  cx.fillStyle='#a1887f'; cx.fillRect(gx+2,gy+8,gw-4,3);
  // post caps
  cx.fillStyle='#4e342e';
  cx.fillRect(gx-2,gy+2,14,6); cx.fillRect(gx-1,gy-1,12,5); cx.fillRect(gx+2,gy-3,8,3);
  cx.fillRect(gx+gw-12,gy+2,14,6); cx.fillRect(gx+gw-11,gy-1,12,5); cx.fillRect(gx+gw-10,gy-3,8,3);
  // vines — purple, no green
  cx.fillStyle='#7a4888';
  for(let i=0;i<gh-20;i+=10){ cx.fillRect(gx+1,gy+16+i,3,5); cx.fillRect(gx-2,gy+20+i,3,3); }
  for(let i=0;i<gh-20;i+=10){ cx.fillRect(gx+gw-4,gy+14+i,3,5); cx.fillRect(gx+gw+1,gy+18+i,3,3); }
  cx.fillStyle='#9a68aa';
  for(let i=0;i<gh-20;i+=14){ cx.fillRect(gx+2,gy+18+i,5,3); cx.fillRect(gx+gw-7,gy+16+i,5,3); }
  // rose buds
  cx.fillStyle='#e91e63';
  [[gx+2,gy+16],[gx+gw-8,gy+22],[gx+2,gy+42],[gx+gw-8,gy+48]].forEach(([rx,ry])=>{
    cx.fillRect(rx,ry,5,4); cx.fillRect(rx+1,ry-2,3,3);
    cx.fillStyle='#8a2244'; cx.fillRect(rx+2,ry+4,1,5); cx.fillStyle='#e91e63';
  });
  // sparkles
  const t=Date.now()/700;
  cx.fillStyle='#ffecf8';
  [[gx+gw/2,gy+gh*.28],[gx+gw*.3,gy+gh*.58],[gx+gw*.7,gy+gh*.68]].forEach(([sx,sy],i)=>{
    const s=Math.abs(Math.sin(t+i*1.2))*4+1;
    cx.fillRect(sx-s/2,sy-s/2,s,s);
    cx.fillRect(sx-s/4,sy-s,s/2,s*2);
    cx.fillRect(sx-s,sy-s/4,s*2,s/2);
  });
}

function drawBee(b){
  if(!b.alive) return;
  const px=Math.round(b.x-camX), py=Math.round(b.y)+(b.fr%2)*2;
  if(px<-22||px>W+22) return;
  cx.save(); cx.translate(px,py);
  cx.fillStyle='#ffdd00'; cx.fillRect(3,3,13,9);
  cx.fillStyle='#1a0a00'; cx.fillRect(5,4,2,7); cx.fillRect(9,4,2,7); cx.fillRect(13,4,2,5);
  cx.fillStyle='#1a0a00'; cx.fillRect(1,4,4,8);
  cx.fillStyle='#fff'; cx.fillRect(2,5,2,3); cx.fillStyle='#000'; cx.fillRect(3,6,1,2);
  cx.fillStyle='rgba(180,220,255,.75)'; cx.fillRect(4,-1,5,5); cx.fillRect(9,-1,5,5);
  cx.fillStyle='#1a0a00'; cx.fillRect(16,6,3,2);
  cx.restore();
}

function drawParticles(){
  particles.forEach(p=>{
    const px=Math.round(p.x-camX), py=Math.round(p.y);
    cx.globalAlpha=p.life;
    if(p.heart){
      cx.fillStyle=p.col; const s=p.sz;
      cx.fillRect(px-s/2,py,s/2,s/2); cx.fillRect(px,py,s/2,s/2);
      cx.fillRect(px-s*.7,py+s*.3,s*1.4,s*.5); cx.fillRect(px-s*.4,py+s*.8,s*.8,s*.4);
      cx.fillRect(px-s*.2,py+s*1.2,s*.4,s*.3);
    } else {
      cx.fillStyle=p.col; cx.fillRect(px-p.sz/2,py-p.sz/2,p.sz,p.sz);
    }
    cx.globalAlpha=1;
  });
}

// ════════════════════════════════════════
//  PHYSICS
// ════════════════════════════════════════
function overlap(a,b){ return a.x<b.x+b.w && a.x+a.w>b.x && a.y<b.y+b.h && a.y+a.h>b.y; }

function updatePhysics(){
  const ml=K['ArrowLeft']||K['KeyA']||tL;
  const mr=K['ArrowRight']||K['KeyD']||tR;
  const acc=.65, fric=.72, max=3.4;
  if(ml){ P.vx-=acc; P.dir=-1; }
  if(mr){ P.vx+=acc; P.dir=1; }
  if(!ml&&!mr) P.vx*=fric;
  P.vx=Math.max(-max,Math.min(max,P.vx));
  P.vy+=.44;
  P.x+=P.vx; P.y+=P.vy;
  P.onG=false;
  platforms.forEach(p=>{
    if(P.x+P.w>p.x && P.x<p.x+p.w){
      if(P.y+P.h>p.y && P.y+P.h<p.y+p.h+Math.abs(P.vy)+4 && P.vy>=0){
        P.y=p.y-P.h; P.vy=0; P.onG=true;
      }
    }
  });
  if(P.y>H+40){ hurtP(); return; }
  if(!P.inv){
    obstacles.forEach(o=>{ if(overlap({x:P.x+3,y:P.y+3,w:P.w-6,h:P.h-6},o)) hurtP(); });
    bees.forEach(b=>{
      if(!b.alive) return;
      if(P.vy>1 && P.y+P.h-6<b.y+b.h*.5 && overlap({x:P.x,y:P.y+P.h-7,w:P.w,h:8},b)){
        b.alive=false; P.vy=-5.5; score+=10;
        spawnParts(b.x+9,b.y,'#ffdd00'); sfxCoin();
      } else if(overlap({x:P.x+2,y:P.y+2,w:P.w-4,h:P.h-4},b)){ hurtP(); }
    });
  }
  flowers.forEach(f=>{
    if(!f.got && overlap({x:P.x+2,y:P.y+2,w:P.w-4,h:P.h-4},{x:f.x-5,y:f.y-5,w:14,h:14})){
      f.got=true; score+=5; spawnHearts(f.x,f.y); sfxCoin();
    }
  });
  if(P.x<0){ P.x=0; P.vx=0; }
  if(P.x+P.w>WORLD) P.x=WORLD-P.w;
  P.ft++; if(P.ft>6){ P.fr++; P.ft=0; }
  if(P.inv>0){ P.inv--; } else P.inv=0;
  camX=P.x-W/3; camX=Math.max(0,Math.min(WORLD-W,camX));
  if(overlap({x:P.x,y:P.y,w:P.w,h:P.h},gate) && state==='playing') triggerWin();
}

function hurtP(){
  if(P.inv>0) return;
  sfxHurt(); spawnParts(P.x+10,P.y+14,'#ff4444',10);
  lives--; updateHUD();
  if(lives<=0){
    state='dead'; stopMusic();
    saveScore(pName, score, false);
    setTimeout(()=>document.getElementById('gameOverScreen').classList.remove('hidden'),500);
  } else { P.inv=110; P.vx=0; P.vy=-4; }
}

function triggerWin(){
  if(state==='win') return;
  state='win'; stopMusic(); sfxWin();
  saveScore(pName, score, true);
  initWin();
  cv.addEventListener('click', winTap);
  cv.addEventListener('touchstart', winTap, {passive:false});
}

function winTap(e){
  if(e.type==='touchstart') e.preventDefault();
  if(state!=='win') return;
  if(winPhase===3 && winFinalT>80){ restartFromWin(); }
}

// dialogues auto-advance in updateWin, no manual tap needed
function advanceDial(){}

function restartFromWin(){
  cv.removeEventListener('click', winTap);
  cv.removeEventListener('touchstart', winTap);
  startGame();
}

function updateBees(){
  bees.forEach(b=>{
    if(!b.alive) return;
    b.x+=b.spd*b.dir;
    if(b.x>b.bx+b.range||b.x<b.bx-b.range) b.dir*=-1;
    b.ft++; if(b.ft>8){ b.fr++; b.ft=0; }
  });
}
function updateParts(){
  particles.forEach(p=>{ p.x+=p.vx; p.y+=p.vy; p.vy+=.09; p.life-=.027; });
  particles=particles.filter(p=>p.life>0);
}
function updateHUD(){
  document.getElementById('hudLives').textContent=lives>=2?'* *':lives>=1?'*  ':' ';
  document.getElementById('hudScore').textContent=score+' pts';
}

