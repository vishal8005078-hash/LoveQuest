<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Love Quest</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
body{
  background:#08040f;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  min-height:100vh;overflow:hidden;touch-action:none;
  font-family:'Press Start 2P',monospace;
}
#wrap{position:relative;width:100%;max-width:480px;margin:0 auto;}
#gameCanvas{display:block;width:100%;image-rendering:pixelated;
  border:3px solid #c84888;
  box-shadow:0 0 28px #c84888bb,0 0 60px #c8488844;}

/* ── HUD ── */
#hud{
  display:flex;justify-content:space-between;align-items:center;
  padding:5px 10px;background:rgba(0,0,0,0.8);
  border-bottom:2px solid #c84888;
  border-left:3px solid #c84888;border-right:3px solid #c84888;
  font-size:clamp(5px,1.5vw,7px);color:#ffccdd;position:relative;z-index:5;
}
.hud-n{color:#ffaad4;font-size:clamp(6px,1.8vw,9px);}

/* ── CONTROLS ── */
#controls{
  display:flex;justify-content:space-between;align-items:center;
  padding:8px 14px;background:rgba(0,0,0,0.88);
  border:3px solid #c84888;border-top:2px solid #c84888;
  border-radius:0 0 4px 4px;gap:8px;
}
.cg{display:flex;gap:6px;}
.cb{
  font-family:'Press Start 2P',monospace;font-size:clamp(9px,3vw,13px);
  background:linear-gradient(135deg,#2a0840,#4a0a60);color:#ffccdd;
  border:3px solid #c84888;padding:11px 14px;border-radius:4px;
  cursor:pointer;box-shadow:3px 3px 0 #6a0040;
  user-select:none;-webkit-user-select:none;
  min-width:50px;min-height:50px;display:flex;align-items:center;justify-content:center;
}
.cb:active{transform:translate(2px,2px);box-shadow:1px 1px 0 #6a0040;background:#c84888;}
.cj{background:linear-gradient(135deg,#c84888,#e870aa);min-width:58px;min-height:58px;}

/* ── GAME OVER ── */
.overlay{position:absolute;inset:0;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:14px;z-index:20;padding:18px;text-align:center;}
#gameOverScreen{background:rgba(4,0,10,0.95);}
.ov-title{font-size:clamp(12px,3.5vw,18px);line-height:1.9;}
.ov-sub{font-size:clamp(5px,1.8vw,7px);color:#ffccdd;line-height:2.4;}
.btn-ov{font-family:'Press Start 2P',monospace;font-size:clamp(6px,2vw,8px);
  background:#c84888;color:#fff;border:3px solid #fff;padding:10px 20px;
  cursor:pointer;box-shadow:3px 3px 0 #6a0040;}

/* ── DEV TAG ── */
#devTag{
  position:fixed;bottom:9px;right:11px;
  font-size:clamp(4px,1.3vw,6px);color:#c8488844;
  pointer-events:none;text-align:right;line-height:2;z-index:100;
  letter-spacing:.5px;
}
#devTag b{animation:dpulse 2.2s ease-in-out infinite;display:inline-block;}
@keyframes dpulse{0%,100%{color:#c8488866;}50%{color:#c848aacc;}}
.hidden{display:none!important;}
</style>
</head>
<body>
<div id="wrap">
  <div id="hud" class="hidden">
    <div id="hudLives">* *</div>
    <div class="hud-n" id="hudName"></div>
    <div id="hudScore">0 pts</div>
  </div>
  <canvas id="gameCanvas" width="480" height="270"></canvas>
  <div id="controls" class="hidden">
    <div class="cg">
      <button class="cb" id="btnLeft">&#9664;</button>
      <button class="cb" id="btnRight">&#9654;</button>
    </div>
    <button class="cb cj" id="btnJump">JUMP</button>
  </div>
  <div class="overlay hidden" id="gameOverScreen">
    <div class="ov-title" style="color:#ff5588;">oh no!</div>
    <div class="ov-sub">the bees caught you...<br>but love never gives up!</div>
    <button class="btn-ov" id="retryBtn">try again</button>
  </div>
</div>
<div id="devTag">more games from ur<br><b>romantic dev</b></div>

<script>
'use strict';
// ════════════════════════════════════════
//  CANVAS SETUP
// ════════════════════════════════════════
const cv = document.getElementById('gameCanvas');
const cx = cv.getContext('2d');
const W = 480, H = 270;

// ════════════════════════════════════════
//  AUDIO
// ════════════════════════════════════════
let actx = null;
function initAudio(){ if(actx) return; actx = new (window.AudioContext||window.webkitAudioContext)(); }
function tone(f,t,d,v=0.11,tp='sine'){
  if(!actx) return;
  const o=actx.createOscillator(), g=actx.createGain();
  o.connect(g); g.connect(actx.destination);
  o.type=tp; o.frequency.setValueAtTime(f, actx.currentTime+t);
  g.gain.setValueAtTime(0, actx.currentTime+t);
  g.gain.linearRampToValueAtTime(v, actx.currentTime+t+.01);
  g.gain.linearRampToValueAtTime(0, actx.currentTime+t+d);
  o.start(actx.currentTime+t); o.stop(actx.currentTime+t+d+.05);
}
const sfxJump  = ()=>{ tone(380,0,.05,.16); tone(660,0,.09,.12); };
const sfxHurt  = ()=>{ tone(200,0,.13,.2,'sawtooth'); tone(150,.12,.18,.18,'sawtooth'); };
const sfxCoin  = ()=>{ tone(880,0,.04,.16); tone(1100,.05,.07,.12); };
const sfxWin   = ()=>{ [523,659,784,988,1047].forEach((f,i)=>tone(f,i*.18,.2,.2)); };
const sfxClick = ()=>{ tone(660,0,.06,.12); };
let bgTimer=null;
function startMusic(){
  if(!actx) return;
  const S=[261,294,329,392,440,494,523,587];
  const M=[4,5,6,5,4,2,0,1,2,4,3,2,1,0,2,3,5,4,3,2,1,3,4,5,6,5];
  let i=0;
  function n(){
    if(!actx) return;
    tone(S[M[i%M.length]]*.5,0,.38,.055,'triangle');
    tone(S[M[i%M.length]],0,.32,.045,'sine');
    i++; bgTimer=setTimeout(n,390);
  } n();
}
function stopMusic(){ clearTimeout(bgTimer); bgTimer=null; }

// ════════════════════════════════════════
//  STATE MACHINE
// ════════════════════════════════════════
// states: 'title' | 'nameinput' | 'story' | 'playing' | 'win' | 'dead'
let state = 'title';
let pName = 'Angel';
let lives = 2, score = 0, camX = 0;

// ════════════════════════════════════════
//  INPUT
// ════════════════════════════════════════
const K = {};
let tL=false, tR=false, tJ=false, tJused=false;
document.addEventListener('keydown', e=>{
  K[e.code]=true;
  if((e.code==='Space'||e.code==='ArrowUp') && !tJused){ tJused=true; doJump(); }
  if(e.code==='Enter' || e.code==='Space'){
    handleScreenTap();
  }
});
document.addEventListener('keyup', e=>{ K[e.code]=false; if(e.code==='Space'||e.code==='ArrowUp') tJused=false; });

function mkBtn(id, dn, up){
  const b=document.getElementById(id);
  b.addEventListener('touchstart',e=>{ e.preventDefault(); initAudio(); dn(); },{passive:false});
  b.addEventListener('touchend',  e=>{ e.preventDefault(); up(); },{passive:false});
  b.addEventListener('mousedown', ()=>{ initAudio(); dn(); });
  b.addEventListener('mouseup',   up);
  b.addEventListener('mouseleave',up);
}
mkBtn('btnLeft',  ()=>tL=true,  ()=>tL=false);
mkBtn('btnRight', ()=>tR=true,  ()=>tR=false);
mkBtn('btnJump',  ()=>{ if(!tJ){ tJ=true; doJump(); } }, ()=>tJ=false);

// ════════════════════════════════════════
//  PIXEL FONT HELPER (draw on canvas)
// ════════════════════════════════════════
function pxText(text, x, y, size, color, align='left'){
  cx.save();
  cx.font = size+'px "Press Start 2P"';
  cx.fillStyle = color;
  cx.textAlign = align;
  cx.textBaseline = 'top';
  cx.fillText(text, x, y);
  cx.restore();
}
function pxTextShadow(text, x, y, size, color, shadow, sx=2, sy=2){
  cx.save();
  cx.font = size+'px "Press Start 2P"';
  cx.textAlign = 'center';
  cx.textBaseline = 'top';
  cx.fillStyle = shadow;
  cx.fillText(text, x+sx, y+sy);
  cx.fillStyle = color;
  cx.fillText(text, x, y);
  cx.restore();
}

// ════════════════════════════════════════
//  INTRO / TITLE SCREEN  (all on canvas)
// ════════════════════════════════════════
let titleT = 0; // frame counter for title animations

// animated particles on title screen
const titleParticles = [];
for(let i=0;i<28;i++){
  titleParticles.push({
    x: Math.random()*W, y: Math.random()*H,
    vx: (Math.random()-.5)*.3, vy: -.2-Math.random()*.5,
    life: Math.random(), maxLife:1,
    size: 1+Math.random()*2,
    col: ['#c84888','#e870aa','#ffaad4','#ff80c0','#ffffff'][Math.floor(Math.random()*5)]
  });
}

function drawTitleScreen(){
  titleT++;
  // background
  const bg = cx.createLinearGradient(0,0,0,H);
  bg.addColorStop(0,'#08040f');
  bg.addColorStop(.5,'#180830');
  bg.addColorStop(1,'#2a0a30');
  cx.fillStyle=bg; cx.fillRect(0,0,W,H);

  // floating pixel particles
  titleParticles.forEach(p=>{
    p.x+=p.vx; p.y+=p.vy; p.life+=.008;
    if(p.y<-4||p.life>p.maxLife){ p.y=H+4; p.x=Math.random()*W; p.life=0; }
    cx.globalAlpha=Math.sin(p.life*Math.PI)*0.7;
    cx.fillStyle=p.col;
    cx.fillRect(Math.round(p.x), Math.round(p.y), p.size, p.size);
    cx.globalAlpha=1;
  });

  // moon
  cx.fillStyle='#ffe0f0';
  cx.beginPath(); cx.arc(W-70, 45, 22, 0, Math.PI*2); cx.fill();
  cx.fillStyle='#c8a8c0';
  cx.beginPath(); cx.arc(W-60, 38, 17, 0, Math.PI*2); cx.fill();
  // moon glow
  const mg=cx.createRadialGradient(W-70,45,18,W-70,45,55);
  mg.addColorStop(0,'rgba(255,200,230,.14)'); mg.addColorStop(1,'rgba(255,200,230,0)');
  cx.fillStyle=mg; cx.beginPath(); cx.arc(W-70,45,55,0,Math.PI*2); cx.fill();

  // silhouette trees
  cx.fillStyle='#140420';
  [[20,H,16,80],[60,H,14,60],[110,H,18,95],[170,H,12,50],[220,H,20,110],
   [290,H,14,65],[350,H,18,88],[410,H,13,55],[450,H,17,75]].forEach(([tx,ty,tw,th])=>{
    cx.fillRect(tx-tw/2, ty-th, tw, th);
    cx.fillRect(tx-tw, ty-th-30, tw*2, 35);
    cx.fillRect(tx-tw*.7, ty-th-55, tw*1.4, 30);
  });

  // scanline shimmer
  cx.fillStyle='rgba(255,180,220,.025)';
  for(let i=0;i<H;i+=2) cx.fillRect(0,i,W,1);

  // pixel border frame
  cx.strokeStyle='#c84888'; cx.lineWidth=3;
  cx.strokeRect(2,2,W-4,H-4);
  cx.strokeStyle='#e870aa'; cx.lineWidth=1;
  cx.strokeRect(6,6,W-12,H-12);
  // corner dots
  [[8,8],[W-10,8],[8,H-10],[W-10,H-10]].forEach(([px,py])=>{
    cx.fillStyle='#ffaad4'; cx.fillRect(px-2,py-2,4,4);
  });

  // TITLE TEXT
  const pulse = Math.sin(titleT*.04)*2;
  cx.save();
  cx.shadowColor='#c84888'; cx.shadowBlur=24+pulse*3;
  pxTextShadow('LOVE QUEST', W/2, 36+pulse, 20, '#ffaad4', '#6a0040', 3, 3);
  cx.restore();

  // subtitle
  pxTextShadow('a pixelated love story 🌸', W/2, 72, 5, '#cc88aa', '#3a0030', 1, 1);

  // top pixel rule
  cx.fillStyle='#c84888';
  for(let i=40;i<W-40;i+=7){ cx.fillRect(i,88,3,1); }

  // romantic lines fading in one by one
  const RLINES = [
    { t:'somewhere in the forest...',      col:'#cc88aa', size:6, d:0   },
    { t:'fireflies were dancing 🌿',        col:'#ffaad4', size:6, d:30  },
    { t:'and a boy stood waiting',          col:'#cc88aa', size:6, d:60  },
    { t:'holding a single rose 🌹',         col:'#ff80c0', size:6, d:90  },
    { t:'just for her.',                    col:'#ffaad4', size:7, d:120 },
  ];
  RLINES.forEach((l,i)=>{
    const age = titleT - l.d;
    if(age <= 0) return;
    const a = Math.min(age/18, 1);
    const yo = (1 - Math.min(age/22,1)) * 8;
    cx.globalAlpha = a;
    pxTextShadow(l.t, W/2, 100 + i*22 + yo, l.size, l.col, '#1a0018', 1, 1);
    cx.globalAlpha = 1;
  });

  // bottom pixel rule
  const ruleAlpha = Math.min(Math.max(titleT-125,0)/15, 1);
  cx.globalAlpha = ruleAlpha * .5;
  cx.fillStyle='#c84888';
  for(let i=60;i<W-60;i+=7){ cx.fillRect(i,216,3,1); }
  cx.globalAlpha = 1;

  // "made by Vishal" — appears last
  const mba = Math.min(Math.max(titleT-130,0)/18, 1);
  cx.globalAlpha = mba;
  pxTextShadow('made with 💕 by Vishal', W/2, 223, 5, '#e870aa', '#2a0020', 1, 1);
  cx.globalAlpha = 1;

  // floating emoji row
  const ef = Math.sin(titleT*.06)*3;
  const ea = Math.min(Math.max(titleT-148,0)/18, 1);
  cx.save();
  cx.font='11px serif'; cx.textAlign='center'; cx.textBaseline='middle';
  cx.globalAlpha = ea;
  cx.fillText('🌸', W/2-44, 240+ef);
  cx.fillText('✨', W/2,    237+ef*.5);
  cx.fillText('🌸', W/2+44, 240+ef);
  cx.restore();
  cx.globalAlpha = 1;

  // blinking press anywhere
  if(titleT > 60 && Math.floor(titleT/30)%2===0){
    pxTextShadow('- press anywhere -', W/2, H-28, 5, '#ffaad4', '#3a0030', 1, 1);
  }

  // SCOREBOARD button — bottom right corner
  const sbBx=W-88, sbBy=H-20, sbBw=82, sbBh=15;
  cx.fillStyle='rgba(200,72,136,.2)'; cx.fillRect(sbBx,sbBy,sbBw,sbBh);
  cx.strokeStyle='#c84888'; cx.lineWidth=1.5; cx.strokeRect(sbBx,sbBy,sbBw,sbBh);
  pxTextShadow('scores 🏆', sbBx+sbBw/2, sbBy+3, 4, '#ffaad4', '#3a0030', 1, 1);
  cv._sbBtn = {x:sbBx, y:sbBy, w:sbBw, h:sbBh};
}


// ════════════════════════════════════════
//  NAME INPUT SCREEN  (canvas)
// ════════════════════════════════════════
let nameInput = '';
let nameCursor = 0; // blink frame
let nameShake = 0;  // shake on empty submit

// We capture keyboard on this screen
let nameKeyHandler = null;

function activateNameInput(){
  nameInput = '';
  nameCursor = 0;
  nameShake = 0;
  nameKeyHandler = (e)=>{
    if(state !== 'nameinput') return;
    if(e.key === 'Backspace'){ nameInput = nameInput.slice(0,-1); sfxClick(); }
    else if(e.key === 'Enter'){ submitName(); }
    else if(e.key.length===1 && nameInput.length<10){
      nameInput += e.key; sfxClick();
    }
  };
  document.addEventListener('keydown', nameKeyHandler);
  // tap canvas = submit
  cv.addEventListener('click', nameScreenTap);
  cv.addEventListener('touchstart', nameScreenTap, {passive:false});
}
function deactivateNameInput(){
  if(nameKeyHandler){ document.removeEventListener('keydown', nameKeyHandler); nameKeyHandler=null; }
  cv.removeEventListener('click', nameScreenTap);
  cv.removeEventListener('touchstart', nameScreenTap);
}
function nameScreenTap(e){
  if(state !== 'nameinput') return;
  if(e.type==='touchstart') e.preventDefault();
  submitName();
}
function submitName(){
  pName = nameInput.trim() || 'Angel';
  sfxClick();
  deactivateNameInput();
  state = 'story';
  storyT = 0; storyLine = 0;
}

let nameT = 0;
function drawNameScreen(){
  nameT++;
  // background - deep forest night
  const bg=cx.createLinearGradient(0,0,0,H);
  bg.addColorStop(0,'#08040f'); bg.addColorStop(.6,'#1a062a'); bg.addColorStop(1,'#240830');
  cx.fillStyle=bg; cx.fillRect(0,0,W,H);

  // animated rising sparkles
  titleParticles.forEach(p=>{
    p.x+=p.vx; p.y+=p.vy; p.life+=.01;
    if(p.y<-4||p.life>p.maxLife){ p.y=H+4; p.x=Math.random()*W; p.life=0; }
    cx.globalAlpha=Math.sin(p.life*Math.PI)*.5;
    cx.fillStyle=p.col;
    cx.fillRect(Math.round(p.x), Math.round(p.y), p.size, p.size);
    cx.globalAlpha=1;
  });

  // silhouette trees (same as title)
  cx.fillStyle='#12021e';
  [[20,H,14,70],[80,H,16,90],[150,H,12,55],[240,H,18,100],[320,H,14,68],[400,H,17,85],[460,H,11,48]].forEach(([tx,ty,tw,th])=>{
    cx.fillRect(tx-tw/2,ty-th,tw,th);
    cx.fillRect(tx-tw,ty-th-28,tw*2,32);
    cx.fillRect(tx-tw*.7,ty-th-50,tw*1.4,26);
  });

  // pixel border
  cx.strokeStyle='#c84888'; cx.lineWidth=3; cx.strokeRect(2,2,W-4,H-4);
  cx.strokeStyle='#8a2860'; cx.lineWidth=1; cx.strokeRect(6,6,W-12,H-12);
  [[8,8],[W-10,8],[8,H-10],[W-10,H-10]].forEach(([px,py])=>{
    cx.fillStyle='#c84888'; cx.fillRect(px-2,py-2,4,4);
  });

  // decorative top strip
  cx.fillStyle='rgba(200,72,136,.08)'; cx.fillRect(0,0,W,H*.3);
  // header rule
  cx.fillStyle='#c84888';
  for(let i=20;i<W-20;i+=6) cx.fillRect(i,52,3,1);
  for(let i=20;i<W-20;i+=6) cx.fillRect(i,H-54,3,1);

  // Title small
  pxTextShadow('LOVE QUEST', W/2, 18, 10, '#ffaad4', '#6a0040', 2, 2);

  // Main prompt
  pxTextShadow("what's your name?", W/2, 64, 7, '#e890c8', '#3a0028', 1, 1);

  // input box
  const shk = nameShake>0 ? Math.sin(nameShake*.8)*4 : 0;
  if(nameShake>0) nameShake--;
  const bx=W/2-90+shk, by=90, bw=180, bh=26;
  cx.fillStyle='rgba(20,4,36,0.9)';
  cx.fillRect(bx, by, bw, bh);
  cx.strokeStyle='#c84888'; cx.lineWidth=3;
  cx.strokeRect(bx, by, bw, bh);
  // inner highlight
  cx.strokeStyle='#e870aa44'; cx.lineWidth=1;
  cx.strokeRect(bx+3,by+3,bw-6,bh-6);

  // input text
  cx.save();
  cx.font='8px "Press Start 2P"';
  cx.textAlign='center'; cx.textBaseline='middle';
  cx.fillStyle='#ffffff';
  const displayTxt = nameInput + (Math.floor(nameT/20)%2===0 ? '_' : ' ');
  cx.fillText(displayTxt, W/2+shk, by+bh/2);
  cx.restore();

  // hint text
  pxTextShadow('leave blank = Angel', W/2, 126, 5, '#6a3858', '#00000000', 0, 0);

  // pixel girl walking in loop
  const gWalkX = 50 + ((nameT*1.2)%160);
  drawWalkGirl(Math.round(gWalkX), H-62, Math.floor(nameT/8)%4);

  // ENTER button
  const btnBob = Math.sin(nameT*.07)*2;
  const bx2=W/2-44, by2=148+btnBob;
  cx.fillStyle='#c84888';
  cx.fillRect(bx2, by2, 88, 22);
  cx.fillStyle='#e870aa';
  cx.fillRect(bx2, by2, 88, 4);
  cx.fillStyle='#6a0040';
  cx.fillRect(bx2+3, by2+18, 85, 4);
  cx.save();
  cx.font='7px "Press Start 2P"';
  cx.fillStyle='#fff'; cx.textAlign='center'; cx.textBaseline='middle';
  cx.fillText('ENTER', W/2, by2+11);
  cx.restore();

  // tap detection for ENTER button
  cv._nameBtn = {x:bx2, y:by2, w:88, h:22};
}

function drawWalkGirl(x, y, fr){
  cx.save(); cx.translate(x, y);
  cx.fillStyle='#ff80b0'; cx.fillRect(3,10,10,10);
  cx.fillStyle='#ff4d9e'; cx.fillRect(1,17,12,5);
  cx.fillStyle='#ffd4a8'; cx.fillRect(4,4,8,8);
  cx.fillRect(3,-3,9,9);
  cx.fillStyle='#8b1a4a'; cx.fillRect(2,-3,10,3); cx.fillRect(2,0,2,4); cx.fillRect(10,0,2,4);
  cx.fillStyle='#ff3381'; cx.fillRect(9,-5,5,3);
  cx.fillStyle='#1a0808'; cx.fillRect(5,0,2,2); cx.fillRect(8,0,2,2);
  cx.fillStyle='#ffd4a8';
  const lo=fr<2?0:3;
  cx.fillRect(4,22,4,6+lo); cx.fillRect(8,22,4,6+(3-lo));
  cx.fillStyle='#8b1a4a'; cx.fillRect(3,28,5,2); cx.fillRect(7,28,5,2);
  const ao=fr<2?-2:2;
  cx.fillStyle='#ffd4a8'; cx.fillRect(-1,8+ao,3,7); cx.fillRect(13,8-ao,3,7);
  cx.restore();
}

// ════════════════════════════════════════
//  STORY SCREEN  (canvas)
// ════════════════════════════════════════
let storyT = 0;
let storyLine = 0;
const STORY_LINES = [
  { text:'🌿  deep in a quiet forest  🌿', col:'#ffaad4', size:6 },
  { text:'lived a girl named',             col:'#cc88aa', size:6 },
  { text:'???',                             col:'#ffddee', size:11, nameReplace:true },
  { text:'she ran, jumped & chased',       col:'#cc88aa', size:6 },
  { text:'fireflies through the woods ✨',  col:'#cc88aa', size:6 },
  { text:'but today was different 💫',     col:'#ffaad4', size:7 },
  { text:'at the end of the forest',       col:'#cc88aa', size:6 },
  { text:'someone special was waiting 🌹', col:'#ff80c0', size:6 },
  { text:'his name was Vishal.',           col:'#ffaad4', size:7 },
  { text:'can she reach him? 💕',          col:'#e870aa', size:7 },
];
const STORY_DELAY = 48;

function drawStoryScreen(){
  storyT++;
  const bg=cx.createLinearGradient(0,0,0,H);
  bg.addColorStop(0,'#08040f'); bg.addColorStop(.5,'#140820'); bg.addColorStop(1,'#1a062a');
  cx.fillStyle=bg; cx.fillRect(0,0,W,H);

  // soft radial glow center
  const sg=cx.createRadialGradient(W/2,H/2,10,W/2,H/2,130);
  sg.addColorStop(0,'rgba(200,72,136,.08)'); sg.addColorStop(1,'rgba(200,72,136,0)');
  cx.fillStyle=sg; cx.fillRect(0,0,W,H);

  // particles
  titleParticles.forEach(p=>{
    p.x+=p.vx; p.y+=p.vy; p.life+=.009;
    if(p.y<-4||p.life>p.maxLife){ p.y=H+4; p.x=Math.random()*W; p.life=0; }
    cx.globalAlpha=Math.sin(p.life*Math.PI)*.4;
    cx.fillStyle=p.col;
    cx.fillRect(Math.round(p.x), Math.round(p.y), p.size, p.size);
    cx.globalAlpha=1;
  });

  cx.strokeStyle='#c84888'; cx.lineWidth=3; cx.strokeRect(2,2,W-4,H-4);

  const revealed = Math.floor(storyT / STORY_DELAY);
  storyLine = Math.min(revealed, STORY_LINES.length);

  const lineH = 23;
  const blockH = STORY_LINES.length * lineH;
  const startY = H/2 - blockH/2 - 8;

  STORY_LINES.forEach((l, i)=>{
    if(i >= storyLine) return;
    const age = storyT - i*STORY_DELAY;
    const alpha = Math.min(age/18, 1);
    // slide in from below (smooth easing)
    const ease = 1 - Math.pow(1-Math.min(age/22,1), 3);
    const y = startY + i*lineH + (1-ease)*10;

    // soft glow behind highlighted lines
    if(l.size >= 7 && alpha > 0.5){
      cx.globalAlpha = (alpha-.5)*0.3;
      cx.fillStyle='#c84888';
      const tw2 = l.size*7;
      cx.fillRect(W/2-90, y-2, 180, l.size+6);
      cx.globalAlpha = 1;
    }

    cx.globalAlpha = alpha;
    const txt = l.nameReplace ? pName : l.text;
    pxTextShadow(txt, W/2, y, l.size, l.col, '#2a0020', 1, 1);
    cx.globalAlpha = 1;
  });

  if(storyLine >= STORY_LINES.length){
    if(Math.floor(storyT/28)%2===0){
      pxTextShadow('- tap to begin -', W/2, H-24, 5, '#c84888', '#2a0020', 1, 1);
    }
    cv._storyDone = true;
  } else {
    cv._storyDone = false;
  }
}

